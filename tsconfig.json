{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    // "moduleResolution": "NodeNext",
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    // "types": "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework"],
    "paths": {
      "@fixtures/*": ["./src/core/src/fixtures/*"],
      "@pages/*": ["./src/web/pages/*"],
      "@core/*": ["./src/core/src/*"]
    }
  }
}